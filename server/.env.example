NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/jobhunt
JWT_SECRET=change_this_to_a_long_random_secret

# Comma-separated list of allowed frontend origins (CORS).
# In production set to your deployed frontend URL, e.g. https://your-frontend.onrender.com
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Nodemailer (optional — for deadline reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
